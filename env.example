# ── Database ───────────────────────────────────────────────────────────────────
# SQLite via libSQL (local file, no server needed)
DATABASE_URL="file:./dev.db"

# ── Next.js ────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET="change-me-to-a-random-32-char-string"
NEXTAUTH_URL="http://localhost:3000"

# ── Swarm Python API ───────────────────────────────────────────────────────────
# Leave empty to use mock data in development
SWARM_API_URL="http://localhost:8001"

# ── Anthropic (required for live swarm execution) ─────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."

# ── Stripe (required for live payment processing) ─────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ── Redis (optional — required for Celery task queue in production) ────────────
REDIS_URL="redis://localhost:6379/0"

# ── Email / SMTP (optional — for RGPD opt-out notifications) ──────────────────
SMTP_HOST="smtp.example.com"
SMTP_PORT="587"
SMTP_USER="noreply@example.com"
SMTP_PASSWORD=""

# ── Google Maps (optional — Division 1 prospect detection) ────────────────────
GOOGLE_MAPS_API_KEY=""

# ── PageSpeed Insights (optional — Division 1 scoring) ────────────────────────
PAGESPEED_API_KEY=""
