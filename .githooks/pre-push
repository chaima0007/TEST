#!/usr/bin/env bash
# pre-push — Garde anti-collision de branche CaelumSwarm™ (protocole §15)
# Bloque le push si une autre session a modifié la branche distante.
set -e

BRANCH=$(git rev-parse --abbrev-ref HEAD 2>/dev/null)

# Ne garder que la branche de travail principale (les autres projets passent)
if [ "$BRANCH" != "claude/swarm-50-agent-architecture-3l6cno" ]; then
  exit 0
fi

if [ ! -f scripts/branch_guard.py ]; then
  exit 0  # garde absent → ne pas bloquer
fi

echo "🛡️  branch_guard : vérification anti-collision avant push…"
if python3 scripts/branch_guard.py --check --quiet; then
  exit 0
else
  echo ""
  echo "🛑 PUSH BLOQUÉ par branch_guard (protocole §15)."
  echo "   La branche distante a été modifiée par une autre session."
  echo "   Résous la divergence avant de pousser :"
  echo "     python3 scripts/branch_guard.py --check"
  echo ""
  echo "   (Pour forcer en connaissance de cause : git push --no-verify)"
  exit 1
fi
